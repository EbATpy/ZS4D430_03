@EndUserText.label: 'Abteilung Zugriffssteuerung Ü17'
@MappingRole: true
define role Z03_R_DEPARTMENT {
    grant 
        select
            on
                Z03_R_DEPARTMENT
                    where
                        (Id) = aspect pfcg_auth(Z03DPMENT, Z03DPMNT , ACTVT = '03' );
                        
}